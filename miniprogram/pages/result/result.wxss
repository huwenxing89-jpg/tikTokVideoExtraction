/* pages/result/result.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 作者卡片 */
.author-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.author-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

/* 内容卡片 */
.content-card {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* 视频播放器 */
.video-wrapper {
  position: relative;
  width: 100%;
}

.video-player {
  width: 100%;
  height: 420rpx;
}

.video-duration {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  background: #000;
}

.image-counter {
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #666;
}

/* 标题 */
.video-title {
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 数据统计 */
.stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 28rpx;
}

.stat-value {
  font-size: 28rpx;
  color: #666;
}

/* 操作按钮 */
.action-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.action-btn:last-child {
  margin-bottom: 0;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn.outline {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.action-btn:active {
  opacity: 0.9;
}

.action-btn[disabled] {
  opacity: 0.6;
}

.btn-icon {
  font-size: 36rpx;
}

.action-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80vh;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* pages/index/index.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Logo 区域 */
.logo-section {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #fe2c55 0%, #ff6b6b 100%);
  border-radius: 30rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.logo-title {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
}

.logo-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 输入区域 */
.input-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.input-wrapper {
  margin-bottom: 30rpx;
}

.input-area {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.action-btn:active {
  background: #e0e0e0;
}

.action-icon {
  font-size: 28rpx;
}

/* 解析按钮 */
.parse-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.parse-btn:active {
  opacity: 0.9;
}

.parse-btn.disabled {
  opacity: 0.6;
}

/* 使用说明链接 */
.help-link {
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #667eea;
}

/* 历史记录 */
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.history-clear {
  font-size: 26rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  gap: 20rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.history-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-item-title {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.history-meta {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.history-type {
  background: #667eea;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

/* 底部说明 */
.footer {
  text-align: center;
  padding: 60rpx 0 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
